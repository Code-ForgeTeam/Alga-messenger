{
    "name":  "alga-messenger-restored",
    "private":  true,
    "version":  "1.0.0",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "preview":  "vite preview",
                    "lint":  "tsc --noEmit",
                    "cap:sync":  "npm run build \u0026\u0026 npx cap sync",
                    "cap:add:android":  "npx cap add android",
                    "cap:add:ios":  "npx cap add ios",
                    "cap:open:android":  "npm run cap:sync:android \u0026\u0026 npx cap open android",
                    "android:build":  "npm run cap:sync \u0026\u0026 npm run cap:open:android",
                    "setup:local":  "bash ./scripts/bootstrap-all-local.sh",
                    "cap:prepare:android":  "npx cap add android",
                    "cap:prepare:ios":  "npx cap add ios",
                    "cap:sync:android":  "npx cap sync android",
                    "cap:sync:ios":  "npx cap sync ios",
                    "cap:open:android:auto":  "bash ./scripts/cap-open-android.sh"
                },
    "dependencies":  {
                         "@capacitor/android":  "^7.0.0",
                         "@capacitor/app":  "^7.0.0",
                         "@capacitor/core":  "^7.0.0",
                         "@capacitor/ios":  "^7.6.0",
                         "@capacitor/local-notifications":  "^7.0.0",
                         "@emotion/react":  "^11.13.3",
                         "@emotion/styled":  "^11.13.0",
                         "@mui/icons-material":  "^6.1.0",
                         "@mui/material":  "^6.1.0",
                         "axios":  "^1.7.9",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1",
                         "react-router-dom":  "^6.27.0",
                         "socket.io-client":  "^4.8.1",
                         "zustand":  "^5.0.0"
                     },
    "devDependencies":  {
                            "@capacitor/cli":  "^7.0.0",
                            "@types/react":  "^18.3.12",
                            "@types/react-dom":  "^18.3.1",
                            "@vitejs/plugin-react":  "^4.3.3",
                            "typescript":  "^5.6.3",
                            "vite":  "^5.4.10"
                        }
}